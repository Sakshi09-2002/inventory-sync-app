<div class="inventory-status-container" id="inventory-status-{{ block.id }}">
  <h4 style="margin-bottom: 10px;">Available at:</h4>
  <div id="inventory-locations-{{ block.id }}" class="inventory-locations">
    {% comment %} Content populated by JS {% endcomment %}
    <p class="inventory-loading">Checking availability...</p>
  </div>
</div>

<script>
  (function() {
    const blockId = '{{ block.id }}';
    const container = document.getElementById(`inventory-locations-${blockId}`);
    
    // Store all location tags for this product in a JS-accessible format
    const allLocationTags = [
      {% for tag in product.tags %}
        {% if tag contains 'loc_' %}
          "{{ tag }}"{% unless forloop.last %},{% endunless %}
        {% endif %}
      {% endfor %}
    ];

    const updateLocations = () => {
      // 1. Get current variant ID from URL or default
      const urlParams = new URLSearchParams(window.location.search);
      let currentVariantId = urlParams.get('variant');
      
      if (!currentVariantId) {
        // Fallback to Liquid's initial variant if no URL param
        currentVariantId = "{{ product.selected_or_first_available_variant.id }}";
      }

      // Ensure we have a clean numeric ID for comparison
      const cleanVariantId = currentVariantId.toString().split('/').pop();

      // 2. Filter tags that match the current variant
      // Tags are formatted as: loc_locationname_variantid
      const matchingTags = allLocationTags.filter(tag => {
        const parts = tag.split('_');
        const tagVariantId = parts[parts.length - 1];
        return tagVariantId === cleanVariantId;
      });

      // 3. Render
      if (matchingTags.length === 0) {
        container.innerHTML = '<p class="inventory-none">No stock available for this variant at any location.</p>';
        return;
      }

      const html = matchingTags.map(tag => {
        // Extract location name from tag (between first 'loc_' and last '_variantid')
        const parts = tag.split('_');
        const locationPart = parts.slice(1, -1).join(' ');
        const locationName = locationPart.charAt(0).toUpperCase() + locationPart.slice(1);
        
        return `
          <div class="inventory-location">
            <span class="location-dot"></span>
            ${locationName}
          </div>
        `;
      }).join('');

      container.innerHTML = html;
    };

    // Run on load
    updateLocations();

    // Listen for URL changes (Shopify themes often update URL without full reload)
    window.addEventListener('popstate', updateLocations);
    
    // Some themes use custom events or AJAX for variant changes
    // We can also poll frequently if needed, or hook into common theme events
    const observer = new MutationObserver(() => {
        updateLocations();
    });
    
    // Observe the URL for changes if needed, or simply re-check every few seconds as a fallback
    setInterval(updateLocations, 2000); 
  })();
</script>

<style>
  .inventory-status-container {
    margin: 1.5rem 0;
    padding: 1.2rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.8rem;
    background: #f8fafc;
    color: {{ block.settings.text_color }};
  }
  .inventory-locations {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .inventory-location {
    display: flex;
    align-items: center;
    font-weight: 500;
  }
  .location-dot {
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    display: inline-block;
    margin-right: 10px;
  }
  .inventory-none, .inventory-loading {
    color: #64748b;
    font-style: italic;
    font-size: 0.9em;
  }
</style>
{% schema %}
{
  "name": "Inventory Status",
  "target": "section",
  "settings": []
}
{% endschema %}