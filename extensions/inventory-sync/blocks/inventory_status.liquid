{% schema %}
{
  "name": "Inventory Status",
  "target": "section",
  "templates": ["product"],
  "settings": [
    { "type": "product", "id": "product", "label": "Product", "autofill": true },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": "Loading Text",
      "default": "Loading inventory..."
    }
  ]
}
{% endschema %}

<style>
  .inventory-status-container {
    margin: 1.5rem 0;
    padding: 1rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    color: {{ block.settings.text_color }};
  }
  .inventory-location {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
    border-bottom: 1px solid #f1f5f9;
  }
  .inventory-location:last-child {
    border-bottom: none;
  }
  .inventory-quantity {
    font-weight: bold;
  }
  .inventory-error {
    color: #ef4444;
  }
</style>

<div class="inventory-status-container" id="inventory-status-{{ block.id }}">
  <div class="inventory-header">
    <label for="location-select-{{ block.id }}">Available at:</label>
    <select id="location-select-{{ block.id }}" class="location-dropdown">
      <option value="">Select a location</option>
    </select>
  </div>
  <div class="inventory-content" style="margin-top: 10px; font-size: 0.9em;"></div>
</div>

<script>
  (function() {
    const blockId = '{{ block.id }}';
    const container = document.getElementById(`inventory-status-${blockId}`);
    const select = document.getElementById(`location-select-${blockId}`);
    const content = container.querySelector('.inventory-content');
    const productId = '{{ product.id }}';
    
    let variantMapping = {};

    const fetchAllInventory = async () => {
      content.innerHTML = '{{ block.settings.loading_text }}';
      try {
        const response = await fetch(`/apps/inventory-sync/inventory?productId=${productId}`);
        if (!response.ok) throw new Error('Network response was not ok');
        
        const data = await response.json();
        variantMapping = data.variantMapping;
        populateDropdown();
      } catch (error) {
        console.error('Error fetching inventory:', error);
        content.innerHTML = '<p class="inventory-error">Error loading inventory.</p>';
      }
    };

    const populateDropdown = () => {
      const locationMap = new Map();

      // Collect all unique locations that have stock in AT LEAST one variant
      for (const variantId in variantMapping) {
        variantMapping[variantId].forEach(level => {
          if (level.available > 0) {
            if (!locationMap.has(level.locationName)) {
              locationMap.set(level.locationName, {
                name: level.locationName,
                variantId: variantId,
                available: level.available
              });
            }
          }
        });
      }

      if (locationMap.size === 0) {
        content.innerHTML = '<p>No stock available at any location.</p>';
        select.style.display = 'none';
        return;
      }

      locationMap.forEach((loc, name) => {
        const option = document.createElement('option');
        option.value = loc.variantId;
        option.textContent = name;
        select.appendChild(option);
      });
    };

    select.addEventListener('change', (e) => {
      const variantId = e.target.value;
      if (!variantId) {
        content.innerHTML = '';
        return;
      }

      // Convert GID to numeric ID for URL if needed, but Shopify handles both usually
      const numericId = variantId.split('/').pop();
      const url = new URL(window.location.href);
      url.searchParams.set('variant', numericId);
      
      // Update content to show stock for selected location
      const selectedLocName = e.target.options[e.target.selectedIndex].text;
      const stock = variantMapping[variantId].find(l => l.locationName === selectedLocName)?.available;
      content.innerHTML = `<strong>${stock}</strong> available at this location. Redirecting...`;

      // Redirect
      window.location.href = url.toString();
    });

    fetchAllInventory();
  })();
</script>
